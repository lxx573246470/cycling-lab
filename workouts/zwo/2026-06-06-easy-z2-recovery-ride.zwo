    <SteadyState Duration="720" Power="0.62"/>
    <SteadyState Duration="240" Power="0.55"/>
    <SteadyState Duration="1080" Power="0.65"/>
    <SteadyState Duration="300" Power="0.55"/>
    <SteadyState Duration="300" Power="0.52"/>
    <Cooldown Duration="180" PowerLow="0.45" PowerHigh="0.40"/>
  </workout>
