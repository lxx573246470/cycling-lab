<workout_file>
  <author>cycling-lab</author>
  <name>2026-06-06 Easy Z2 Recovery Ride</name>
  <description>Easy indoor Z2 the day after a rest day and one day before a long outdoor fit-adaptation ride. FTP reference: 200 W. Keep heart rate in 122-142 bpm, cadence 85-92 rpm, and downgrade if HR or fit discomfort rises.</description>
  <sportType>bike</sportType>
  <tags>
    <tag name="endurance"/>
    <tag name="z2"/>
    <tag name="recovery"/>
    <tag name="week 23"/>
  </tags>
  <workout>
